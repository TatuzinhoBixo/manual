            "source_raw": [
              {
                "data": "#cloud-config\nhostname: vm-control1\nmanage_etc_hosts: true\npackage_update: true\npackage_upgrade: true\npackages:\n  - qemu-guest-agent\nusers:\n  - default\n  - name: devopstatu\n    shell: /bin/bash\n    sudo: ALL=(ALL) NOPASSWD:ALL\n    lock_passwd: true\n    ssh_authorized_keys:\n      - ssh-rsa  devopstatu@localhost.localdomain\nssh_pwauth: false\nruncmd:\n  - systemctl enable qemu-guest-agent\n  - systemctl start qemu-guest-agent\n",
                "file_name": "cloud_config-vm-control1.yaml",
                "resize": 0
